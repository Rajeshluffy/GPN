<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    GPN Smoke Suite — DATAPROVIDER mode
    ─────────────────────────────────────────────────────────────────────
    executionMode="DATAPROVIDER"
      @Factory reads every row in GPN Account.xlsx and creates one instance
      of each test class per account.  Adding a new account to the Excel
      automatically runs all test classes for that account — no XML change
      needed.

      Example: 31 accounts × 2 test classes = 62 instances executed.

    Concurrency:
      parallel="instances" → each factory instance runs in its own thread.
      thread-count="4"     → at most 4 browsers concurrently; rest queue.
      maxPoolSize="4"      → driver-pool hard cap matches thread-count.

    To run in STANDARD mode (single account), use gpn-standard.xml.
    ─────────────────────────────────────────────────────────────────────
-->
<suite name="GPN Master Suite" parallel="instances" thread-count="4" verbose="1">

    <parameter name="executionMode" value="DATAPROVIDER" />
    <parameter name="configClass"  value="com.alfaDOCK.config.data.AlfaDockConfiguration" />
    <parameter name="environment"  value="dev" />
    <parameter name="browser"      value="chrome" />
    <parameter name="maxPoolSize"  value="4" />


    <test name="GPN ERP Tests">
        <parameter name="excelPath" value="src/test/resources/GPN Account - ERP.xlsx" />
        <classes>
            <class name="com.gpn.testcases.TC000_GPN_BEEP_SettingsChange" />
        </classes>
    </test>

</suite>
