# Copy this file to .env.gpn (already gitignored) and fill in real values.
# Used by docker-compose.yml for local STANDARD-mode runs (gpn-standard.xml).
# In Jenkins/Kubernetes these same names are supplied via the Credentials
# store / a Secret instead — see Jenkinsfile / k8s/gpn-secret.yaml.

ALFADOCK_COMPANY_USER=
ALFADOCK_COMPANY_PASS=
ALFADOCK_USER_USER=
ALFADOCK_USER_PASS=
